# Copy this file to proxy/.env and fill in your API keys.
# proxy/.env is gitignored and will never be committed.
# The extension UI key takes precedence if set; these act as fallbacks.
# Leave a key commented out if you don't use that provider.

# ── Server ──────────────────────────────────────────────────────────────────────
# PORT=3000          # Port the proxy listens on
# MOCK=false         # Set to true to return fake responses (no API keys needed)

# ── API Keys ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── Claude / Anthropic ───────────────────────────────────────────────────────────
# CLAUDE_MAX_TOKENS=1024        # Max output tokens for Claude requests
# ANTHROPIC_VERSION=2023-06-01  # Anthropic API version header

# ── Local LLM (Ollama / LM Studio) ──────────────────────────────────────────────
# LOCAL_LLM_HOST=localhost  # Host for local LLM server
# LOCAL_LLM_PORT=11434      # Port for local LLM server (Ollama default: 11434)

# ── Proxy behaviour ──────────────────────────────────────────────────────────────
# CORS_ORIGIN=*          # Allowed CORS origin (* = any; restrict in production)
# MOCK_INTERVAL_MS=80    # Milliseconds between mock SSE token chunks

# ── Feature flags ────────────────────────────────────────────────────────────────
# FEATURE_DOCUMENTS_SECTION=true       # Show the Documents (resume/file upload) section
# FEATURE_AUDIT_PANEL=true             # Show the Audit tab (consent + token usage log)
# FEATURE_COST_BADGE=true              # Show estimated cost badge after each fill
# FEATURE_ATTACHMENT_FILLING=false     # Send uploaded files to AI when filling forms
# FEATURE_PERSONAL_SECTION=true        # Show the Personal Info section in Profile
# FEATURE_EMPLOYMENT_SECTION=true      # Show the Employment Info section in Profile
# FEATURE_EDUCATION_SECTION=true       # Show the Education section in Profile
# FEATURE_CUSTOM_FIELDS_SECTION=true   # Show the Custom Fields section in Profile
# FEATURE_JUDGING_SECTION=true         # Show the Judging section in Profile
# FEATURE_MENTORING_SECTION=true       # Show the Mentoring section in Profile
# FEATURE_SPEAKER_SECTION=true         # Show the Speaker section in Profile
# FEATURE_SCHOLARSHIP_SECTION=true              # Show the Scholarship / Study Application section in Profile
# FEATURE_PROFESSIONAL_ACCOUNTS_SECTION=true   # Show the Professional Accounts section in Profile
