# Copy this file to proxy/.env and fill in your API keys.
# proxy/.env is gitignored and will never be committed.
# The extension UI key takes precedence if set; these act as fallbacks.
# Leave a key commented out if you don't use that provider.

# ── Server ──────────────────────────────────────────────────────────────────────
# PORT=3000          # Port the proxy listens on
# MOCK=false         # Set to true to return fake responses (no API keys needed)

# ── API Keys ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── Claude / Anthropic ───────────────────────────────────────────────────────────
# CLAUDE_MAX_TOKENS=1024        # Max output tokens for Claude requests
# ANTHROPIC_VERSION=2023-06-01  # Anthropic API version header

# ── Local LLM (Ollama / LM Studio) ──────────────────────────────────────────────
# LOCAL_LLM_HOST=localhost  # Host for local LLM server
# LOCAL_LLM_PORT=11434      # Port for local LLM server (Ollama default: 11434)

# ── Proxy behaviour ──────────────────────────────────────────────────────────────
# CORS_ORIGIN=*          # Allowed CORS origin (* = any; restrict in production)
# MOCK_INTERVAL_MS=80    # Milliseconds between mock SSE token chunks
